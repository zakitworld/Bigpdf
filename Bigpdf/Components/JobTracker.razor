@inject IJobService JobService
@implements IDisposable

@if (_job is not null)
{
    <div class="job-card" style="width: 100%; max-width: 520px; text-align: left; margin-top: 1.25rem;">
        <div style="display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--border-color); padding-bottom: 0.75rem; margin-bottom: 1rem;">
            <div style="display: flex; align-items: center; gap: 0.5rem;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <polyline points="12 6 12 12 16 14"/>
                </svg>
                <strong style="font-size: 0.95rem; color: var(--text-primary);">Conversion status</strong>
            </div>
            
            <div>
                @switch (_job.Status)
                {
                    case JobStatus.Pending:
                        <span class="alert alert-warning" style="padding: 0.25rem 0.6rem; margin: 0; font-size: 0.8rem; border-radius: var(--radius-full); display: inline-flex;">Queued</span>
                        break;
                    case JobStatus.Running:
                        <span class="alert alert-success" style="padding: 0.25rem 0.6rem; margin: 0; font-size: 0.8rem; border-radius: var(--radius-full); display: inline-flex; background: var(--primary-light); color: var(--primary); border-color: transparent;">Processing</span>
                        break;
                    case JobStatus.Completed:
                        <span class="alert alert-success" style="padding: 0.25rem 0.6rem; margin: 0; font-size: 0.8rem; border-radius: var(--radius-full); display: inline-flex;">Completed</span>
                        break;
                    case JobStatus.Failed:
                        <span class="alert alert-error" style="padding: 0.25rem 0.6rem; margin: 0; font-size: 0.8rem; border-radius: var(--radius-full); display: inline-flex;">Failed</span>
                        break;
                }
            </div>
        </div>

        @if (_job.Status == JobStatus.Running || _job.Status == JobStatus.Pending)
        {
            <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                <div style="display: flex; align-items: center; gap: 0.75rem;">
                    <div class="spinner" style="width: 1.5rem; height: 1.5rem; border-width: 3px;"></div>
                    <span class="job-progress" style="font-size: 0.9rem; font-weight: 600;">
                        @(_job.Message ?? "Performing operation on document(s)...")
                    </span>
                </div>
                <div class="progress-container" style="max-width: 100%;">
                    <div class="progress-fill" style="@($"width:{GetProgressWidth(_job)}%")"></div>
                </div>
                <div style="display: flex; justify-content: space-between; gap: 1rem;">
                    <span class="hint">@GetProgressWidth(_job)% complete</span>
                    <span class="hint">Elapsed: @FormatElapsed(_job.StartedAt ?? _job.CreatedAt)</span>
                </div>
            </div>
        }
        else if (_job.Status == JobStatus.Completed)
        {
            <div style="display: flex; flex-direction: column; gap: 0.5rem;">
                <span style="font-size: 0.9rem; font-weight: 600; color: var(--success);">@(_job.Message ?? "Operation completed successfully!")</span>
                @if (!string.IsNullOrEmpty(_job.ResultPath))
                {
                    <div style="margin-top: 0.25rem;">
                        <a href="@UploadPaths.ToPublicUrl(_job.ResultPath)" class="btn btn-primary" style="padding: 0.45rem 1rem; font-size: 0.85rem;" target="_blank" download>
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 0.25rem;">
                                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                                <polyline points="7 10 12 15 17 10"/>
                                <line x1="12" y1="15" x2="12" y2="3"/>
                            </svg> Download output
                        </a>
                    </div>
                }
            </div>
        }
        else if (_job.Status == JobStatus.Failed)
        {
            <div style="display: flex; flex-direction: column; gap: 0.25rem;">
                <span class="job-error" style="font-size: 0.9rem; font-weight: 600;">@(_job.Message ?? "Job execution failed.")</span>
                
                @if (IsMissingToolError(_job.Message))
                {
                    <div class="alert alert-warning" style="margin-top: 0.5rem; font-size: 0.85rem; padding: 0.75rem 1rem;">
                        <strong>Missing converter tool.</strong>
                        <div style="margin-top: 0.35rem;">
                            Set the executable path at <a href="/admin/tools">/admin/tools</a>,
                            or run the install scripts in <code>tools/</code>, then restart the app.
                        </div>
                    </div>
                }
            </div>
        }
    </div>
}

@code {
    [Parameter] public string? JobId { get; set; }
    [Parameter] public EventCallback<JobInfo> OnCompleted { get; set; }
    [Parameter] public EventCallback<JobInfo> OnStatusChanged { get; set; }

    private JobInfo? _job;
    private CancellationTokenSource? _pollCts;
    private string? _activeJobId;
    private bool _completionNotified;

    protected override void OnParametersSet()
    {
        if (string.IsNullOrEmpty(JobId) || string.Equals(JobId, _activeJobId, StringComparison.Ordinal))
            return;

        _activeJobId = JobId;
        _completionNotified = false;
        StopPolling();
        _pollCts = new CancellationTokenSource();
        _ = PollJobAsync(_pollCts.Token);
    }

    private async Task PollJobAsync(CancellationToken cancellationToken)
    {
        while (!cancellationToken.IsCancellationRequested)
        {
            try
            {
                var job = JobService.GetJob(_activeJobId!);
                if (job is not null)
                {
                    _job = job;
                    await InvokeAsync(StateHasChanged);

                    if (OnStatusChanged.HasDelegate)
                        await OnStatusChanged.InvokeAsync(job);

                    if (job.Status is JobStatus.Completed or JobStatus.Failed)
                    {
                        if (!_completionNotified && OnCompleted.HasDelegate)
                        {
                            _completionNotified = true;
                            await OnCompleted.InvokeAsync(job);
                        }
                        break;
                    }
                }
            }
            catch
            {
                // keep polling until cancelled
            }

            try
            {
                await Task.Delay(1000, cancellationToken);
            }
            catch (OperationCanceledException)
            {
                break;
            }
        }
    }

    private void StopPolling()
    {
        _pollCts?.Cancel();
        _pollCts?.Dispose();
        _pollCts = null;
    }

    public void Dispose() => StopPolling();

    private static int GetProgressWidth(JobInfo job)
    {
        if (job.Status == JobStatus.Completed) return 100;
        if (job.Status == JobStatus.Failed) return 0;
        return Math.Clamp(job.ProgressPercent ?? 10, 5, 95);
    }

    private static bool IsMissingToolError(string? message) =>
        !string.IsNullOrEmpty(message) &&
        (message.Contains("Ghostscript", StringComparison.OrdinalIgnoreCase)
         || message.Contains("Tesseract", StringComparison.OrdinalIgnoreCase)
         || message.Contains("LibreOffice", StringComparison.OrdinalIgnoreCase));

    private static string FormatElapsed(DateTime startedAt)
    {
        var elapsed = DateTime.UtcNow - startedAt;
        if (elapsed.TotalMinutes >= 1)
            return $"{(int)elapsed.TotalMinutes}m {elapsed.Seconds}s";

        return $"{Math.Max(0, elapsed.Seconds)}s";
    }
}
