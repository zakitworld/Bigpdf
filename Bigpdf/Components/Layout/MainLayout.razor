@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Routing

<header class="site-header">
    <div class="site-brand">
        <a href="/">
            <span class="brand-mark" aria-hidden="true">
                <span></span><span></span><span></span>
                <span></span><span></span><span></span>
                <span></span><span></span><span></span>
            </span>
            Big<span>pdf</span>
        </a>
    </div>
    <nav class="site-nav" aria-label="Primary navigation">
        <NavLink href="/" class="nav-link nav-tools" Match="NavLinkMatch.All">Tools <span aria-hidden="true">v</span></NavLink>
        <NavLink href="/compress" class="nav-link" Match="NavLinkMatch.Prefix">Compress</NavLink>
        <NavLink href="/office" class="nav-link" Match="NavLinkMatch.Prefix">Convert</NavLink>
        <NavLink href="/merge" class="nav-link" Match="NavLinkMatch.Prefix">Merge</NavLink>
        <NavLink href="/pagenumbers" class="nav-link" Match="NavLinkMatch.Prefix">Edit</NavLink>
        <NavLink href="/watermark" class="nav-link" Match="NavLinkMatch.Prefix">Sign</NavLink>
        <NavLink href="/ocr" class="nav-link" Match="NavLinkMatch.Prefix">AI PDF</NavLink>
        <NavLink href="/jobs" class="nav-link" Match="NavLinkMatch.Prefix">Jobs</NavLink>
    </nav>
    <div class="site-actions">
        <AuthorizeView>
            <Authorized>
                <span class="nav-user">@context.User.Identity?.Name</span>
                <form method="post" action="/logout" class="nav-logout" style="display: inline;">
                    <button type="submit" class="btn-signout">Sign out</button>
                </form>
            </Authorized>
            <NotAuthorized>
                <a href="/login" class="login-link">Log In</a>
            </NotAuthorized>
        </AuthorizeView>
        <a class="trial-button" href="/compress">Free Trial</a>
    </div>
</header>

<main class="site-main">
    @Body
</main>

<footer class="site-footer">
    <div class="footer-brand">
        <a href="/" class="footer-logo">
            <span class="brand-mark" aria-hidden="true">
                <span></span><span></span><span></span>
                <span></span><span></span><span></span>
                <span></span><span></span><span></span>
            </span>
            Big<span>pdf</span>
        </a>
        <p>We make PDF easy.</p>
    </div>
    <div class="footer-column">
        <h2>Solutions</h2>
        <a href="/">Sales</a>
        <a href="/">Finance</a>
        <a href="/">Real Estate</a>
        <a href="/">Education</a>
    </div>
    <div class="footer-column">
        <h2>Company</h2>
        <a href="/">About</a>
        <a href="/">Help</a>
        <a href="/">Blog</a>
        <a href="/">PDF Statistics</a>
    </div>
    <div class="footer-column">
        <h2>Product</h2>
        <a href="/compress">Pricing</a>
        <a href="/jobs">Teams</a>
        <a href="/">Developers</a>
        <a href="/">Accessible PDF</a>
    </div>
    <div class="footer-column">
        <h2>Apps</h2>
        <a href="/">Download Bigpdf</a>
        <a href="/pdftojpg">PDF Scanner</a>
        <a href="/">Windows App</a>
    </div>
</footer>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
