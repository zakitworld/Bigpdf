@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Routing

<header class="site-header">
    <div class="site-brand">
        <a href="/">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--primary);">
                <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/>
                <polyline points="14 2 14 8 20 8"/>
            </svg>
            Big<span>pdf</span>
        </a>
    </div>
    <nav class="site-nav" aria-label="Primary navigation">
        <NavLink href="/" class="nav-link" Match="NavLinkMatch.All">Dashboard</NavLink>
        <NavLink href="/compress" class="nav-link" Match="NavLinkMatch.Prefix">Compress</NavLink>
        <NavLink href="/merge" class="nav-link" Match="NavLinkMatch.Prefix">Merge</NavLink>
        <NavLink href="/split" class="nav-link" Match="NavLinkMatch.Prefix">Split</NavLink>
        <NavLink href="/pdftojpg" class="nav-link" Match="NavLinkMatch.Prefix">PDF to JPG</NavLink>
        <NavLink href="/ocr" class="nav-link" Match="NavLinkMatch.Prefix">OCR</NavLink>
        <NavLink href="/office" class="nav-link" Match="NavLinkMatch.Prefix">PDF to Word</NavLink>
        <NavLink href="/convert" class="nav-link" Match="NavLinkMatch.Prefix">Images to PDF</NavLink>
        <NavLink href="/watermark" class="nav-link" Match="NavLinkMatch.Prefix">Watermark</NavLink>
        <NavLink href="/pagenumbers" class="nav-link" Match="NavLinkMatch.Prefix">Page #</NavLink>
        <NavLink href="/jobs" class="nav-link" Match="NavLinkMatch.Prefix">Jobs</NavLink>
        <AuthorizeView>
            <Authorized>
                <span class="nav-user">@context.User.Identity?.Name</span>
                <form method="post" action="/logout" class="nav-logout" style="display: inline;">
                    <button type="submit" class="btn-signout">Sign out</button>
                </form>
            </Authorized>
            <NotAuthorized>
                <a href="/login" class="btn btn-primary" style="color: white; padding: 0.4rem 1rem;">Sign in</a>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</header>

<main class="site-main">
    @Body
</main>

<footer class="site-footer">
    <p>&copy; @DateTime.UtcNow.Year Bigpdf. Built to industry standards using .NET Blazor Server &amp; PdfSharpCore.</p>
</footer>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
