@page "/edit"
@using global::Bigpdf.Models
@using global::Bigpdf.Services
@inject IPdfService PdfService
@inject IJSRuntime JS
@rendermode InteractiveServer

<div class="workspace-wrapper" style="--tool-gradient: linear-gradient(135deg, #14c3c7, #008080); max-width: 100%;">
    <h2 class="page-title">Edit PDF online</h2>
    <p class="page-subtitle">Add text, annotations, signatures, and shape elements to your PDF directly in the browser.</p>

    <div class="reader-layout" style="display: flex; gap: 1.5rem; margin-top: 2rem; min-height: 700px; flex-wrap: wrap;">
        <!-- Left Sidebar: Instructions & Saved Documents -->
        <div class="reader-sidebar" style="flex: 1; min-width: 280px; max-width: 350px; background: var(--bg-surface); padding: 1.5rem; border-radius: var(--radius-md); border: 1px solid var(--border-color); box-shadow: var(--shadow-sm); display: flex; flex-direction: column; gap: 1rem;">
            <div style="background: var(--primary-light); padding: 1rem; border-radius: var(--radius-sm); border-left: 4px solid var(--primary);">
                <h4 style="font-weight: 700; color: var(--primary); font-size: 0.95rem; margin-bottom: 0.35rem; display: flex; align-items: center; gap: 0.25rem;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/>
                    </svg>
                    How to Edit:
                </h4>
                <ol style="margin-left: 1.25rem; font-size: 0.85rem; color: var(--text-secondary); line-height: 1.4; display: flex; flex-direction: column; gap: 0.35rem;">
                    <li>Select a PDF file to edit (or upload a new one).</li>
                    <li>Use the <strong>built-in editing toolbar</strong> at the top of the PDF window (Add Text, Draw, etc.).</li>
                    <li>When done, click the <strong>Save</strong> icon (or press <strong>Ctrl + S</strong>) in the toolbar to save your changes.</li>
                </ol>
            </div>

            <h3 style="font-size: 1.1rem; font-weight: 700; color: var(--text-primary); border-bottom: 2px solid var(--border-color); padding-bottom: 0.5rem; display: flex; align-items: center; gap: 0.5rem;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="color: var(--primary);">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                </svg>
                Select File
            </h3>

            <!-- File Upload -->
            <input @ref="_fileInputRef" type="file" accept=".pdf" class="form-control" style="font-size: 0.85rem; padding: 0.35rem 0.5rem;" @onchange="StartJsUpload" />

            <!-- Documents List -->
            <div style="flex-grow: 1; overflow-y: auto; max-height: 400px; display: flex; flex-direction: column; gap: 0.5rem; margin-top: 0.5rem;">
                @if (_savedFiles == null)
                {
                    <div style="text-align: center; color: var(--text-muted); font-size: 0.9rem; padding: 1rem;">Loading...</div>
                }
                else if (!_savedFiles.Any())
                {
                    <div style="text-align: center; color: var(--text-muted); font-size: 0.9rem; padding: 1rem; border: 1px dashed var(--border-color); border-radius: var(--radius-sm);">
                        No PDF files uploaded yet. Add a PDF file to begin.
                    </div>
                }
                else
                {
                    @foreach (var file in _savedFiles)
                    {
                        var isSelected = string.Equals(file, _selectedFile, StringComparison.OrdinalIgnoreCase);
                        <button class="file-item-btn" @onclick="() => SelectFile(file)" 
                                style="width: 100%; text-align: left; padding: 0.75rem; border-radius: var(--radius-sm); border: 1px solid @(isSelected ? "var(--primary)" : "var(--border-color)"); background: @(isSelected ? "var(--primary-light)" : "transparent"); color: @(isSelected ? "var(--primary)" : "var(--text-secondary)"); font-weight: @(isSelected ? "600" : "500"); cursor: pointer; display: flex; align-items: center; gap: 0.5rem; transition: var(--transition); outline: none;">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink: 0; color: @(isSelected ? "var(--primary)" : "var(--text-muted)");">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                                <polyline points="14 2 14 8 20 8"/>
                            </svg>
                            <span style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap; flex-grow: 1;">@file</span>
                        </button>
                    }
                }
            </div>
        </div>

        <!-- Right Panel: PDF Viewer/Editor Frame -->
        <div class="reader-viewer" style="flex: 2; min-width: 450px; background: var(--bg-surface); padding: 1rem; border-radius: var(--radius-md); border: 1px solid var(--border-color); box-shadow: var(--shadow-sm); display: flex; flex-direction: column;">
            @if (!string.IsNullOrEmpty(_selectedFile))
            {
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border-color); flex-wrap: wrap; gap: 0.5rem;">
                    <div style="display: flex; align-items: center; gap: 0.5rem; max-width: 70%;">
                        <strong style="font-size: 1rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">Editing: @_selectedFile</strong>
                    </div>
                    <div style="display: flex; gap: 0.5rem;">
                        <a href="@UploadPaths.ToPublicUrl($"uploads/{_selectedFile}")" target="_blank" class="btn btn-secondary" style="font-size: 0.85rem; padding: 0.4rem 0.75rem; text-decoration: none; color: var(--text-primary); display: flex; align-items: center; gap: 0.25rem;">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                                <polyline points="15 3 21 3 21 9"/>
                                <line x1="10" y1="14" x2="21" y2="3"/>
                            </svg> Open in New Window
                        </a>
                    </div>
                </div>

                <div style="flex-grow: 1; height: 750px; position: relative;">
                    <iframe src="@($"{UploadPaths.ToPublicUrl($"uploads/{_selectedFile}")}#toolbar=1")" 
                            width="100%" 
                            height="100%" 
                            style="border: none; border-radius: var(--radius-sm); background: #525659; box-shadow: inset 0 0 10px rgba(0,0,0,0.15);">
                    </iframe>
                </div>
            }
            else
            {
                <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 1rem; padding: 5rem 2rem; color: var(--text-muted); text-align: center; height: 100%; border: 2px dashed var(--border-color); border-radius: var(--radius-md); background: var(--bg-main);">
                    <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color: var(--text-muted);">
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                        <path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4z"/>
                    </svg>
                    <div>
                        <h4 style="color: var(--text-primary); font-weight: 700; margin-bottom: 0.25rem;">Select Document to Edit</h4>
                        <p style="font-size: 0.9rem;">Choose an existing PDF or upload a new one to start adding annotations, text, or highlights.</p>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private IEnumerable<string>? _savedFiles;
    private string? _selectedFile;
    private ElementReference _fileInputRef;
    private DotNetObjectReference<Edit>? _dotNetRef;
    private readonly Dictionary<string, string> _uploadIds = new(StringComparer.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        await LoadFilesAsync();
        if (_savedFiles?.Any() == true)
        {
            _selectedFile = _savedFiles.First();
        }
    }

    private async Task LoadFilesAsync()
    {
        var allFiles = await PdfService.ListFilesAsync();
        _savedFiles = allFiles.Where(f => f.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase));
    }

    private void SelectFile(string file)
    {
        _selectedFile = file;
    }

    private async Task StartJsUpload(ChangeEventArgs e)
    {
        _dotNetRef?.Dispose();
        _dotNetRef = DotNetObjectReference.Create(this);
        try
        {
            await JS.InvokeVoidAsync("startUploadsFromElement", _fileInputRef, _dotNetRef, new { chunkSize = 1024 * 256, concurrency = 3, maxRetries = 3 });
        }
        catch (JSException jsEx)
        {
            await JS.InvokeVoidAsync("alert", $"Upload failed: {jsEx.Message}");
        }
    }

    [JSInvokable]
    public Task UploadStarted(string fileName, string uploadId)
    {
        _uploadIds[fileName] = uploadId;
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task ReportProgress(string fileName, double percent)
    {
        return Task.CompletedTask;
    }

    [JSInvokable]
    public async Task UploadCompleted(string fileName, string relativePath, bool success, string? error)
    {
        await LoadFilesAsync();
        if (success && !string.IsNullOrEmpty(relativePath))
        {
            _selectedFile = Path.GetFileName(relativePath);
        }
        else if (!success)
        {
            await JS.InvokeVoidAsync("alert", $"Upload failed: {error ?? "Unknown error"}");
        }
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        _dotNetRef?.Dispose();
    }
}
