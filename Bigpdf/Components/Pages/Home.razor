@page "/"
@using Microsoft.AspNetCore.Components.Forms
@using Bigpdf.Services
@using Bigpdf.Models
@using System.IO
@implements IDisposable
@inject IPdfService PdfService
@inject NavigationManager NavigationManager

<h2 class="page-title">Supercharge Your PDF Workflows</h2>
<p class="page-subtitle">Premium, industry-standard tools to merge, split, compress, convert, and OCR documents instantly.</p>

<div class="dashboard-grid">
    <!-- Compress -->
    <a class="tool-card" href="/compress" style="--tool-gradient: var(--grad-compress);">
        <div class="tool-icon-wrapper">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 14h16M4 10h16M12 3v7M12 21v-7"/>
            </svg>
        </div>
        <h4>Compress PDF</h4>
        <p>Reduce file size dramatically while preserving maximum quality and formatting.</p>
    </a>

    <!-- Merge -->
    <a class="tool-card" href="/merge" style="--tool-gradient: var(--grad-merge);">
        <div class="tool-icon-wrapper">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 5v14M5 12h14"/>
            </svg>
        </div>
        <h4>Merge PDF</h4>
        <p>Combine multiple PDF files into a single, cohesive document in seconds.</p>
    </a>

    <!-- Split -->
    <a class="tool-card" href="/split" style="--tool-gradient: var(--grad-split);">
        <div class="tool-icon-wrapper">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M16 3H1v18h15zM23 7v10M19 11h4"/>
            </svg>
        </div>
        <h4>Split PDF</h4>
        <p>Extract specific page ranges or split every page into separate PDF files.</p>
    </a>

    <!-- PDF to JPG -->
    <a class="tool-card" href="/pdftojpg" style="--tool-gradient: var(--grad-jpg);">
        <div class="tool-icon-wrapper">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
                <circle cx="12" cy="13" r="4"/>
            </svg>
        </div>
        <h4>PDF to JPG</h4>
        <p>Extract images or render pages of a PDF into high-quality JPEG images.</p>
    </a>

    <!-- OCR -->
    <a class="tool-card" href="/ocr" style="--tool-gradient: var(--grad-ocr);">
        <div class="tool-icon-wrapper">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="8" y1="13" x2="16" y2="13"/>
                <line x1="8" y1="17" x2="16" y2="17"/>
                <line x1="10" y1="9" x2="9" y2="9"/>
            </svg>
        </div>
        <h4>OCR PDF</h4>
        <p>Analyze scanned PDF documents and extract editable text using Tesseract OCR.</p>
    </a>

    <!-- PDF to Word -->
    <a class="tool-card" href="/office" style="--tool-gradient: var(--grad-word);">
        <div class="tool-icon-wrapper">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
                <polyline points="10 9 9 9 8 9"/>
            </svg>
        </div>
        <h4>PDF to Word</h4>
        <p>Convert your PDF files to editable DOCX documents with layout precision.</p>
    </a>

    <!-- Images to PDF -->
    <a class="tool-card" href="/convert" style="--tool-gradient: var(--grad-img);">
        <div class="tool-icon-wrapper">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                <circle cx="8.5" cy="8.5" r="1.5"/>
                <polyline points="21 15 16 10 5 21"/>
            </svg>
        </div>
        <h4>Images to PDF</h4>
        <p>Convert JPG, PNG, and TIFF images into clean, formatted PDF files.</p>
    </a>

    <!-- Watermark -->
    <a class="tool-card" href="/watermark" style="--tool-gradient: var(--grad-watermark);">
        <div class="tool-icon-wrapper">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
        </div>
        <h4>Watermark PDF</h4>
        <p>Add text stamps or custom watermarks overlaying all pages of your PDF.</p>
    </a>

    <!-- Page Numbers -->
    <a class="tool-card" href="/pagenumbers" style="--tool-gradient: var(--grad-pagenum);">
        <div class="tool-icon-wrapper">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
            </svg>
        </div>
        <h4>Page Numbers</h4>
        <p>Add page counters or customize alignment and positioning of page numbers.</p>
    </a>
</div>

<!-- Storage / Recent Files Section -->
<div class="storage-section">
    <div class="storage-title">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="color: var(--primary);">
            <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
        </svg>
        <span>Storage &amp; Recent Files</span>
    </div>

    <div style="margin-bottom: 1.5rem; display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center;">
        <span class="hint" style="flex-grow: 1;">Upload files directly here to make them available for quick workflows.</span>
        <input @ref="_fileInputRef" type="file" multiple class="btn btn-secondary" style="font-size: 0.85rem; padding: 0.35rem 0.6rem;" @onchange="StartJsUpload" />
    </div>

    @if (_results?.Any() == true)
    {
        <div style="margin-bottom: 1rem;">
            @foreach (var r in _results)
            {
                <div class="alert @(r.Success ? "alert-success" : "alert-error")" style="padding: 0.5rem 1rem; font-size: 0.85rem;">
                    @(r.Success ? "Successfully uploaded: " : "Failed: ") @r.Message
                </div>
            }
        </div>
    }

    @if (_uploadStatus?.Any() == true)
    {
        <div style="margin-bottom:1rem;">
            @foreach (var kv in _uploadStatus)
            {
                <div class="upload-status">
                    <div style="width:18px; height:18px;">
                        @if (kv.Value.Status == "Uploading...")
                        {
                            <svg class="spinner" width="18" height="18" viewBox="0 0 50 50"><circle cx="25" cy="25" r="20" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-dasharray="31.4 31.4" transform="rotate(-90 25 25)"></circle></svg>
                        }
                    </div>
                    <div style="flex:1">@kv.Key</div>
                    <div style="display:flex; align-items:center; gap:0.5rem;">
                        <div class="progress-container">
                            <div class="progress-fill" style="@($"width:{kv.Value.Percent:F0}%")"></div>
                        </div>
                        <div style="width:48px; text-align:right; font-variant-numeric: tabular-nums;">@($"{kv.Value.Percent:F0}%")</div>
                    </div>
                </div>
            }
        </div>
    }

    @if (_savedFiles?.Any() == true)
    {
        <div class="file-list">
            @foreach (var f in _savedFiles)
            {
                <div class="file-item">
                    <div class="file-info">
                        <span class="file-icon">
                            @if (f.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase))
                            {
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="red" stroke-width="2">
                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                                    <polyline points="14 2 14 8 20 8"/>
                                </svg>
                            }
                            else if (f.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase) || f.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase) || f.EndsWith(".png", StringComparison.OrdinalIgnoreCase))
                            {
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="green" stroke-width="2">
                                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                                    <circle cx="8.5" cy="8.5" r="1.5"/>
                                    <polyline points="21 15 16 10 5 21"/>
                                </svg>
                            }
                            else
                            {
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                                    <polyline points="14 2 14 8 20 8"/>
                                </svg>
                            }
                        </span>
                        <a class="file-name" href="@UploadPaths.ToPublicUrl($"uploads/{f}")" target="_blank">@f</a>
                    </div>
                    <div class="file-actions">
                        <button class="btn btn-secondary" style="padding: 0.35rem 0.6rem; font-size: 0.8rem;" @onclick="() => DeleteFile(f)">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="3 6 5 6 21 6"/>
                                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                            </svg> Delete
                        </button>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-warning" style="margin-top: 1rem;">
            <span>No files uploaded yet. Add files to get started.</span>
        </div>
    }
</div>

@code {
    private List<UploadResult>? _results;
    private List<string>? _savedFiles = new();

    // Tracks per-file upload status and percent shown to the user
    private record UploadState(double Percent, string Status);
    private readonly Dictionary<string, UploadState> _uploadStatus = new(StringComparer.OrdinalIgnoreCase);
    private int _activeUploads = 0;

    private const long MaxFileSize = 1024 * 1024 * 50; // 50 MB
    private ElementReference _fileInputRef;
    [Inject] private IJSRuntime JS { get; set; } = default!;

    private DotNetObjectReference<Home>? _dotNetRef;
    private readonly Dictionary<string, string> _uploadIds = new(StringComparer.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        await RefreshFiles();
    }

    private async Task StartJsUpload(ChangeEventArgs e)
    {
        // create DotNetObjectReference for callbacks from JS
        _dotNetRef?.Dispose();
        _dotNetRef = DotNetObjectReference.Create(this);

        try
        {
            await JS.InvokeVoidAsync("startUploadsFromElement", _fileInputRef, _dotNetRef, new { chunkSize = 1024 * 256, concurrency = 3, maxRetries = 3 });
        }
        catch (JSException jsEx)
        {
            _results ??= new List<UploadResult>();
            _results.Add(new UploadResult(false, jsEx.Message));
            await InvokeAsync(StateHasChanged);
        }
    }

    [JSInvokable]
    public Task UploadStarted(string fileName, string uploadId)
    {
        _uploadIds[fileName] = uploadId;
        return InvokeAsync(StateHasChanged);
    }

    private async Task CancelUpload(string fileName)
    {
        if (_uploadIds.TryGetValue(fileName, out var id))
        {
            await JS.InvokeVoidAsync("cancelUpload", id);
            _uploadIds.Remove(fileName);
            _uploadStatus[fileName] = new UploadState(0, "Canceled");
            await InvokeAsync(StateHasChanged);
        }
    }

    [JSInvokable]
    public Task ReportProgress(string fileName, double percent)
    {
        _uploadStatus[fileName] = new UploadState(percent, "Uploading...");
        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task UploadCompleted(string fileName, string relativePath, bool success, string? error)
    {
        if (success)
        {
            _savedFiles ??= new List<string>();
            if (!string.IsNullOrWhiteSpace(relativePath))
            {
                var savedName = Path.GetFileName(relativePath.Replace('/', Path.DirectorySeparatorChar));
                if (!_savedFiles.Contains(savedName, StringComparer.OrdinalIgnoreCase))
                    _savedFiles.Insert(0, savedName);
            }

            _results ??= new List<UploadResult>();
            _results.Add(new UploadResult(true, fileName, relativePath));
            _uploadStatus[fileName] = new UploadState(100, "Uploaded");
        }
        else
        {
            _results ??= new List<UploadResult>();
            _results.Add(new UploadResult(false, error ?? "Upload failed"));
            _uploadStatus[fileName] = new UploadState(0, error ?? "Upload failed");
        }

        return InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        _dotNetRef?.Dispose();
    }

    private async Task RefreshFiles()
    {
        var list = await PdfService.ListFilesAsync();
        _savedFiles = list?.ToList() ?? new List<string>();
    }

    private async Task HandleQuickUpload(InputFileChangeEventArgs e)
    {
        _results = new List<UploadResult>();

        foreach (var file in e.GetMultipleFiles())
        {
            // mark as uploading and trigger UI update
            _uploadStatus[file.Name] = new UploadState(0, "Uploading...");
            _activeUploads++;
            await InvokeAsync(StateHasChanged);

            try
            {
                await using var stream = file.OpenReadStream(MaxFileSize);
                var relative = await PdfService.SaveFileAsync(stream, file.Name, file.ContentType);

                if (relative != null)
                {
                    // Insert immediately into the displayed file list so it appears without a full refresh
                    var savedName = Path.GetFileName(relative.Replace('/', Path.DirectorySeparatorChar));
                    _savedFiles ??= new List<string>();
                    if (!_savedFiles.Contains(savedName, StringComparer.OrdinalIgnoreCase))
                        _savedFiles.Insert(0, savedName);

                    var successResult = new UploadResult(true, file.Name, relative);
                    await InvokeAsync(() => _results.Add(successResult));
                    _uploadStatus[file.Name] = new UploadState(100, "Uploaded");
                }
                else
                {
                    var failMsg = $"Save failed for {file.Name}";
                    await InvokeAsync(() => _results.Add(new UploadResult(false, failMsg)));
                    _uploadStatus[file.Name] = new UploadState(0, "Save failed");
                }
            }
            catch (Exception ex)
            {
                // Expose error message to the user for troubleshooting
                var error = ex.Message;
                await InvokeAsync(() => _results.Add(new UploadResult(false, error)));
                _uploadStatus[file.Name] = new UploadState(0, error);
            }
            finally
            {
                _activeUploads--;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private async Task DeleteFile(string filename)
    {
        var deleted = await PdfService.DeleteFileAsync(filename);
        if (deleted)
        {
            // remove from the local list to update UI immediately
            _savedFiles?.RemoveAll(n => string.Equals(n, filename, StringComparison.OrdinalIgnoreCase));
            await InvokeAsync(StateHasChanged);
        }
    }
}
