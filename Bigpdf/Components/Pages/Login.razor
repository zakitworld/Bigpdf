@page "/login"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@inject IAdminAuthSettings AuthSettings

<div class="login-container">
    <div class="login-header">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: 0.5rem;">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
        </svg>
        <h3 style="margin-top: 0.5rem; font-size: 1.75rem;">Sign In to Bigpdf</h3>
        <p style="color: var(--text-secondary); font-size: 0.9rem;">Access administrative &amp; workflow processing controls.</p>
    </div>

    <form method="post" action="/auth/login" autocomplete="on">
        <input type="hidden" name="returnUrl" value="@_returnUrl" />
        
        <div class="form-group">
            <label class="form-label" for="username-field">Username</label>
            <input id="username-field" name="username" class="form-control" value="@_model.Username" placeholder="Enter username" required />
        </div>
        
        <div class="form-group" style="margin-bottom: 2rem;">
            <label class="form-label" for="password-field">Password</label>
            <input id="password-field" name="password" type="password" class="form-control" placeholder="Enter password" required />
        </div>

        <button type="submit" class="btn btn-primary" style="width: 100%; padding: 0.85rem; font-size: 1rem;">
            Sign In
        </button>

        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <div class="alert alert-error" style="margin-top: 1.5rem; font-size: 0.875rem;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 0.25rem;">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="12" y1="8" x2="12" y2="12"/>
                    <line x1="12" y1="16" x2="12.01" y2="16"/>
                </svg>
                <span>@_errorMessage</span>
            </div>
        }
    </form>
    
    <div style="margin-top: 2rem; border-top: 1px solid var(--border-color); padding-top: 1.5rem; display: flex; flex-direction: column; gap: 0.75rem;">
        <p class="hint" style="text-align: center;">Default account credentials can be configured using environment variables `BIGPDF_ADMIN_USERNAME` and `BIGPDF_ADMIN_PASSWORD`.</p>
        
        @if (AuthSettings.IsUsingDefaultPassword)
        {
            <div class="alert alert-warning" style="font-size: 0.8rem; padding: 0.5rem 0.75rem; margin: 0;">
                <strong>Security Alert:</strong> The default administrator password is active. Modify this configuration prior to public production environments.
            </div>
        }
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    private string _returnUrl = "/";
    private LoginFormModel _model = new() { Username = "admin" };

    protected override void OnInitialized()
    {
        if (!string.IsNullOrWhiteSpace(ReturnUrl) && ReturnUrl.StartsWith('/'))
            _returnUrl = ReturnUrl;

        _model.Username = AuthSettings.Username;
        _errorMessage = Error == "invalid" ? "Invalid username or password." : null;
    }

    private string? _errorMessage;

    private sealed class LoginFormModel
    {
        public string Username { get; set; } = string.Empty;
    }
}
