@page "/protect"
@using global::Bigpdf.Models
@using global::Bigpdf.Services
@using global::Bigpdf.Components.Shared
@inject IJobService JobService
@rendermode InteractiveServer

<Workspace Title="Protect PDF" 
           Subtitle="Secure your PDF document by encrypting it with a strong password." 
           Gradient="var(--grad-protect)" 
           FileFilter=".pdf" 
           AllowMultiple="false" 
           OutputName="protected.pdf"
           OnDirectSubmit="HandleProtect">
    <SettingsTemplate>
        <div class="form-group" style="margin: 0;">
            <label class="form-label" for="password-input">Password to open document:</label>
            <input type="password" id="password-input" class="form-control" @bind="_password" placeholder="Enter password" />
        </div>
    </SettingsTemplate>
</Workspace>

@code {
    private string _password = "";

    private async Task HandleProtect(Workspace.WorkspaceSubmitEventArgs args)
    {
        if (string.IsNullOrWhiteSpace(_password))
        {
            args.Result = new PdfOperationResult(false, "Password cannot be empty.");
            return;
        }

        var rel = Path.Combine("uploads", args.SelectedFiles.First()).Replace('\\', '/');
        var req = new JobRequest
        {
            Type = JobType.ProtectPdf,
            InputRelativePath = rel,
            Parameters = new Dictionary<string, string>
            {
                ["password"] = _password,
                ["output"] = args.OutputName
            }
        };

        var job = await JobService.EnqueueJobAsync(req);
        while (job.Status == JobStatus.Pending || job.Status == JobStatus.Running)
        {
            await Task.Delay(1000);
            var updated = JobService.GetJob(job.Id);
            if (updated == null) break;
            job = updated;
        }

        if (job.Status == JobStatus.Completed)
        {
            args.Result = new PdfOperationResult(true, job.Message ?? "PDF protected successfully.", job.ResultPath);
        }
        else
        {
            args.Result = new PdfOperationResult(false, job.Message ?? "Failed to encrypt PDF.");
        }
    }
}
