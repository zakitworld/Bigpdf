{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Bigpdf": "Information"
    }
  },

  "AllowedHosts": "*",

  "AdminAuth": {
    "Username": "admin",
    "Password": "ChangeThisPassword123!"
  },

  "FileStorage": {
    "UploadsFolder": "uploads",
    "MaxFileSizeMB": 500,
    "CleanupAfterHours": 24,
    "AllowedExtensions": [ ".pdf", ".docx", ".xlsx", ".png", ".jpg", ".jpeg" ]
  },

  "PdfSettings": {
    "DefaultCompressionQuality": 85,
    "MaxPagesForOCR": 50,
    "WatermarkOpacity": 0.6
  },

  "JobProcessing": {
    "MaxConcurrentJobs": 4,
    "JobTimeoutMinutes": 30
  },

  "Tools": {
    "GhostscriptPath": "",
    "LibreOfficePath": "",
    "TesseractPath": ""
  }
}